// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  password     String
  credits      Int           @default(0)
  createdAt    DateTime      @default(now())
  tasks        Task[]
  usageRecords UsageRecord[]
}

model Task {
  id           String        @id @default(cuid())
  userId       String
  title        String
  status       String        @default("pending")
  currentStep  String        @default("create_script")
  progress     Int           @default(0)
  inputJson    String?
  outputJson   String?
  errorMessage String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id])
  shots        Shot[]
  beats        Beat[]
  assets       Asset[]
  usageRecords UsageRecord[]
}

model Beat {
  id        String @id @default(cuid())
  taskId    String
  beatIndex Int
  goal      String
  event     String
  emotion   String
  duration  Int
  narration String
  shotCount Int
  task      Task   @relation(fields: [taskId], references: [id])
  shots     Shot[]
}

model Shot {
  id              String  @id @default(cuid())
  taskId          String
  beatId          String?
  shotIndex       Int
  sceneText       String?
  cameraAngle     String?
  characterAction String?
  actionVerb      String?
  imagePrompt     String?
  imageUrl        String?
  audioUrl        String?
  status          String  @default("pending")
  task            Task    @relation(fields: [taskId], references: [id])
  beat            Beat?   @relation(fields: [beatId], references: [id])
  assets          Asset[]
}

model Asset {
  id       String  @id @default(cuid())
  taskId   String
  shotId   String?
  type     String // image | audio | video
  url      String
  provider String
  task     Task    @relation(fields: [taskId], references: [id])
  shot     Shot?   @relation(fields: [shotId], references: [id])
}

model UsageRecord {
  id        String   @id @default(cuid())
  userId    String
  taskId    String
  type      String
  credits   Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  task      Task     @relation(fields: [taskId], references: [id])
}
