# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/storyjump?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"
REDIS_HOST="localhost"
REDIS_PORT=6379

# JWT
JWT_SECRET="your-jwt-secret-key"
JWT_EXPIRES_IN="7d"

# DeepSeek LLM
DEEPSEEK_API_KEY="your-deepseek-api-key"
DEEPSEEK_API_BASE_URL="https://api.deepseek.com/v1"
DEEPSEEK_MODEL="deepseek-chat"

# Image Generation (Flux)
IMAGE_API_KEY="your-image-api-key"
IMAGE_API_BASE_URL="https://api.replicate.com/v1"
IMAGE_MODEL="black-forest-labs/flux-schnell"

# TTS (Volcano Engine)
TTS_API_KEY="your-tts-api-key"
TTS_APP_ID="your-volcano-app-id"
TTS_ACCESS_KEY="your-volcano-access-key"
TTS_SECRET_KEY="your-volcano-secret-key"

# Cloud Object Storage (Tencent COS)
COS_SECRET_ID="your-cos-secret-id"
COS_SECRET_KEY="your-cos-secret-key"
COS_BUCKET="your-bucket-name"
COS_REGION="ap-guangzhou"
COS_BASE_URL="https://your-bucket.cos.ap-guangzhou.myqcloud.com"

# App
PORT=3000
NODE_ENV="development"
